# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# Telegram ID администраторов через запятую (узнать можно у @userinfobot)
ADMIN_IDS=123456789,987654321

# Лимит загрузок в сутки на пользователя
DAILY_DOWNLOAD_LIMIT=3

# Задержка между запросами одного пользователя (секунды) — защита от флуда
FLOOD_DELAY_SECONDS=1.5
