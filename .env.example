# Токен от @BotFather
BOT_TOKEN=123456789:AA...

# Работа тюнера на ЛЮБОМ устройстве: залейте web/static на GitHub Pages (см. DEPLOY_MINI_APP.md)
# и вставьте сюда URL без слэша в конце, например https://user.github.io/guitar-bot
HOSTED_MINI_APP_URL=

# Свой URL целиком (ngrok, свой домен) — если задан и валиден, имеет приоритет
WEB_APP_URL=

# 0 — не поднимать туннель Cloudflare (имеет смысл, если задан HOSTED_MINI_APP_URL)
AUTO_CLOUDFLARE_TUNNEL=1

# Локальный сервер для раздачи веб-страницы (по умолчанию ок)
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
